# Lit-Review Orchestrator — API key store
# -----------------------------------------------------------------------------
# Copy this file to your home directory as  ~/.lit-review-pipeline.env  and fill
# in the keys you have. Every pipeline script auto-loads it via python-dotenv.
# Values here are only used when the variable is NOT already set in your shell
# (override=False), so real environment variables always win.
#
#   cp lit-review-pipeline.env.example ~/.lit-review-pipeline.env
#
# Needed by the default (agent-driven) path — search + deep research:
SEARCHAPI_API_KEY=          # Google Scholar (and SSRN/HeinOnline/forthcoming) via SearchAPI.io
GEMINI_API_KEY=             # Stage 2b Gemini Deep Research (default-on alternative deep search)

# Enrichment + autonomous dedup (used in any path; optional):
DEEPSEEK_API_KEY=           # fuzzy title-matching to resolve DOIs during search-result
                            # enrichment (any path), and the LLM fuzzy-dedup pass in the
                            # autonomous orchestrator. Without it, enrichment falls back to
                            # exact title matches.
OPENALEX_API_KEY=           # OpenAlex Premium enrichment (avoids rate limits; optional)
LITREVIEW_CONTACT_EMAIL=    # polite-pool contact sent to OpenAlex/Crossref (courtesy only;
                            # any email works; falls back to a placeholder if unset)

# Autonomous-fallback only: the default agent-driven flow uses NO Anthropic API
# (Opus does Stage 0 extraction, dedup judgments, and screening in-conversation).
# Set this only to run orchestrator.py unattended:
ANTHROPIC_API_KEY=          # Stage 0 extraction, dedup fallback, screening (autonomous only)

# Undermind login (Stage 1 driver). First run can capture these for you:
#   python undermind-search/scripts/undermind_search.py --login
UNDERMIND_EMAIL=
UNDERMIND_PASSWORD=

# Google login for Stage 2 (Scholar Labs). First run captures these for you:
#   python scholarlabs-search/scripts/scholarlabs_search.py --login
# Missing values are prompted for and written here; if already set they pre-fill
# the sign-in so you never re-enter them. Google blocks scripted password entry,
# so the persistent ~/.scholar-profile carries the session (complete any 2FA in
# the window on the first run).
SCHOLAR_EMAIL=
SCHOLAR_PASSWORD=
